# ═══════════════════════════════════════════════════════
# AUREUS SOCIAL PRO — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# ⚠️  Ne jamais committer .env.local
# ═══════════════════════════════════════════════════════

# ─── Supabase (obligatoire)
NEXT_PUBLIC_SUPABASE_URL=https://qcunxnadjxggizdksvay.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.qcunxnadjxggizdksvay.supabase.co:5432/postgres

# ─── Sécurité (obligatoire)
ENCRYPTION_KEY=generate-32-random-chars-here-minimum

# ─── IA — Claude (pour /api/agent)
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── Email (Resend ou SMTP)
MAIL_USER=info@aureus-ia.com
MAIL_PASSWORD=your_mail_password

# ─── Backup Backblaze B2
B2_KEY_ID=your_b2_key_id
B2_APP_KEY=your_b2_application_key
B2_BUCKET_NAME=aureus-backups
B2_ENDPOINT=https://s3.eu-central-003.backblazeb2.com

# ─── Tests E2E Playwright
TEST_EMAIL=your_test_account@example.com
AUREUS_TEST_PASS=your_test_password
TEST_URL=https://app.aureussocial.be
